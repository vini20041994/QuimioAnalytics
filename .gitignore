# ==========================================
# 1. PYTHON E AMBIENTES VIRTUAIS
# ==========================================
# Ignora arquivos compilados que o Python gera sozinho
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignora as pastas de ambientes virtuais (cada um da equipe deve ter o seu local)
venv/
.venv/
env/
.env/

# ==========================================
# 2. JUPYTER NOTEBOOKS E FERRAMENTAS DE DADOS
# ==========================================
# Ignora os checkpoints automáticos do Jupyter
.ipynb_checkpoints/

# ==========================================
# 3. VARIÁVEIS DE AMBIENTE E SEGURANÇA
# ==========================================
# NUNCA suba senhas, credenciais de banco ou chaves de API
.env
.env.local
secrets.json

# ==========================================
# 4. CONFIGURAÇÕES DE IDES E SISTEMA OPERACIONAL
# ==========================================
# Configurações do VSCode e afins
.vscode/
.idea/

# Arquivos inúteis criados pelo Windows ou Mac
.DS_Store
Thumbs.db