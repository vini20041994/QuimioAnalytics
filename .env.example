# Configurações do Banco de Dados PostgreSQL
# Copie este arquivo para .env e ajuste os valores para o seu ambiente.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quimioanalytics
DB_USER=quimio_user
# Atenção: a variável lida pelos scripts é DB_PASS (não DB_PASSWORD)
DB_PASS=quimio_pass_2024
# Host de banco para o backend em container (docker network)
BACKEND_DB_HOST=postgres

# Backend (FastAPI)
BACKEND_PORT=8000
# Upload via API sem ETL externo por padrao para manter resposta interativa.
UPLOAD_RUN_EXTERNAL=0
# Limite maximo em segundos para o subprocesso do upload; use 0 para desabilitar timeout.
UPLOAD_PIPELINE_TIMEOUT_SECONDS=1800

# Frontend (Vite)
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
